<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Product Hero Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="500dp">

            <LinearLayout
                android:id="@+id/detailImgBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_product_img_pink">

                <TextView android:id="@+id/tvDetailBottleName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ROSE\nSÉRUM" android:textSize="16sp"
                    android:fontFamily="serif" android:textStyle="bold"
                    android:textColor="@color/dark2" android:gravity="center"
                    android:lineSpacingMultiplier="1.3" />

                <TextView android:id="@+id/tvDetailEmoji"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌹" android:textSize="48sp" android:layout_marginTop="12dp" />

            </LinearLayout>

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnDetailBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_hero_badge"
                android:src="@drawable/ic_arrow_right"
                android:scaleX="-1"
                android:padding="12dp"
                android:contentDescription="Quay lại" />

            <!-- Badge -->
            <TextView android:id="@+id/tvDetailBadge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="6dp" android:paddingBottom="6dp"
                android:text="-30%" android:textSize="12sp" android:textStyle="bold"
                android:textColor="@color/white" android:visibility="gone" />

        </FrameLayout>

        <!-- Product Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="20dp">

            <TextView android:id="@+id/tvDetailBrand"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LUMIÈRE PARIS" android:textSize="11sp"
                android:textColor="@color/mid" android:letterSpacing="0.1"
                android:textAllCaps="true" android:layout_marginBottom="6dp" />

            <TextView android:id="@+id/tvDetailName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Rose Lumière Sérum"
                android:textSize="22sp" android:fontFamily="serif"
                android:textStyle="bold" android:textColor="@color/dark"
                android:layout_marginBottom="12dp" />

            <!-- Price Row -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView android:id="@+id/tvDetailPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="490k" android:textSize="26sp"
                    android:textStyle="bold" android:textColor="@color/dark"
                    android:layout_marginEnd="12dp" />

                <TextView android:id="@+id/tvDetailOldPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="700k" android:textSize="16sp"
                    android:textColor="@color/mid" android:visibility="gone" />

            </LinearLayout>

            <!-- Description -->
            <TextView android:id="@+id/tvDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sérum dưỡng da cao cấp với công thức độc quyền từ hoa hồng Bulgaria. Cung cấp độ ẩm sâu, làm sáng da và giảm nếp nhăn hiệu quả sau 4 tuần sử dụng."
                android:textSize="14sp" android:textColor="@color/dark2"
                android:lineSpacingMultiplier="1.6" android:layout_marginBottom="20dp" />

            <!-- Ingredients Tags -->
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thành phần nổi bật"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/dark" android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView android:id="@+id/tvIngredient1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_badge"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:text="🌹 Rosa Extract" android:textSize="12sp"
                    android:textColor="@color/dark2" android:layout_marginEnd="8dp" />

                <TextView android:id="@+id/tvIngredient2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_badge"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:text="💧 Hyaluronic" android:textSize="12sp"
                    android:textColor="@color/dark2" android:layout_marginEnd="8dp" />

                <TextView android:id="@+id/tvIngredient3"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_badge"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:text="✨ Niacinamide" android:textSize="12sp"
                    android:textColor="@color/dark2" />

            </LinearLayout>

            <!-- Add to Cart Button -->
            <Button
                android:id="@+id/btnDetailAddToCart"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Bấm để mua sản phẩm"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>