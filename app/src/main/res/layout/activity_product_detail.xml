<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Product Hero -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="500dp">

            <!-- BACKGROUND IMAGE FULL -->
            <FrameLayout
                android:id="@+id/detailImgBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_product_img_pink" />

            <ImageView
                android:id="@+id/imgDetailProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="centerCrop"/>

            <!-- BACK BUTTON -->
            <ImageButton
                android:id="@+id/btnDetailBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="12dp"
                android:layout_gravity="top|start"
                android:background="@drawable/bg_hero_badge"
                android:src="@drawable/ic_arrow_right"
                android:scaleX="-1"
                android:padding="12dp" />

            <!-- BADGE -->
            <TextView
                android:id="@+id/tvDetailBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:visibility="gone" />

        </FrameLayout>

        <!-- INFO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvDetailBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/mid"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/dark"
                android:layout_marginBottom="12dp" />

            <!-- PRICE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvDetailPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark" />

                <TextView
                    android:id="@+id/tvDetailOldPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/mid"
                    android:layout_marginStart="12dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- DESCRIPTION -->
            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/dark2"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="20dp" />

            <!-- INGREDIENT TITLE -->
            <TextView
                android:text="Thành phần nổi bật"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/dark"
                android:layout_marginBottom="8dp" />

            <!-- DYNAMIC INGREDIENT LIST -->
            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/layoutIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:flexWrap="wrap"
                app:flexDirection="row" />

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnDetailAddToCart"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Mua ngay"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>