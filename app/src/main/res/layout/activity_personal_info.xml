<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBackInfo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_hero_badge"
        android:src="@drawable/ic_arrow_right"
        android:scaleX="-1"
        android:padding="8dp"
        android:contentDescription="Quay lại" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin cá nhân"
        android:textSize="22sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="@color/dark"
        android:layout_marginBottom="30dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HỌ VÀ TÊN"
        android:textSize="10sp"
        android:textColor="@color/mid"
        android:letterSpacing="0.1" />
    <TextView
        android:id="@+id/tvShowFullName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nguyễn Ngọc Hân"
        android:textSize="16sp"
        android:textColor="@color/dark"
        android:layout_marginBottom="20dp"
        android:paddingTop="5dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMAIL"
        android:textSize="10sp"
        android:textColor="@color/mid"
        android:letterSpacing="0.1" />
    <TextView
        android:id="@+id/tvShowEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="han@gmail.com"
        android:textSize="16sp"
        android:textColor="@color/dark"
        android:layout_marginBottom="20dp"
        android:paddingTop="5dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SỐ ĐIỆN THOẠI"
        android:textSize="10sp"
        android:textColor="@color/mid"
        android:letterSpacing="0.1" />
    <TextView
        android:id="@+id/tvShowPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0900000002"
        android:textSize="16sp"
        android:textColor="@color/dark"
        android:layout_marginBottom="40dp"
        android:paddingTop="5dp"/>

    <Button
        android:id="@+id/btnGoToEdit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="CHỈNH SỬA HỒ SƠ"
        android:backgroundTint="@color/dark"
        android:textColor="@color/white"
        android:textStyle="bold" />
</LinearLayout>