<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_offers_hero"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ưu đãi đặc biệt"
                android:textSize="24sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết thúc sau"
                android:textSize="13sp"
                android:textColor="@color/lilac2"
                android:layout_marginBottom="16dp" />

            <!-- Countdown Timer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_timer_unit"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:id="@+id/tvHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giờ"
                        android:textSize="10sp"
                        android:textColor="@color/lilac2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_timer_unit"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:id="@+id/tvMinutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phút"
                        android:textSize="10sp"
                        android:textColor="@color/lilac2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_timer_unit">
                    <TextView
                        android:id="@+id/tvSeconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="37"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giây"
                        android:textSize="10sp"
                        android:textColor="@color/lilac2" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Offer Chips -->
        <LinearLayout
            android:id="@+id/offerChipsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp" />

        <!-- Flash Sale Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flash Sale hôm nay"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:textColor="@color/dark"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

        <!-- Flash Sale Item 1 — Pink -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_flash_sale"
            android:padding="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rose Sérum Set"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiết kiệm 40% — chỉ còn 7 suất"
                    android:textSize="12sp"
                    android:textColor="@color/dark2" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_flash_badge">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-40%"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="420k"
                    android:textSize="10sp"
                    android:textColor="@color/lilac2"
                    android:gravity="center" />

            </LinearLayout>
        </LinearLayout>

        <!-- Flash Sale Item 2 — Lilac -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_lilac"
            android:padding="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Velvet Gift Set"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bộ quà tặng cao cấp — giới hạn"
                    android:textSize="12sp"
                    android:textColor="@color/dark2" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_badge">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-25%"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="930k"
                    android:textSize="10sp"
                    android:textColor="@color/lilac2"
                    android:gravity="center" />

            </LinearLayout>
        </LinearLayout>

        <!-- Flash Sale Item 3 — Sage/Green -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_sage"
            android:padding="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Botanica Trio"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sản phẩm dưỡng — combo tốt nhất"
                    android:textSize="12sp"
                    android:textColor="@color/dark2" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_camp_card_2">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-35%"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2tr"
                    android:textSize="10sp"
                    android:textColor="@color/sage2"
                    android:gravity="center" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>