<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chiến dịch"
            android:textSize="24sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:textColor="@color/dark"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp" />

        <!-- Tab Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnCampRunning"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đang chạy"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_primary"
                android:textColor="@color/white"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnCampUpcoming"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Sắp ra mắt"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:textColor="@color/mid"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnCampEnded"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đã kết thúc"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:textColor="@color/mid"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Tiếp cận -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24.8K"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiếp cận"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ +18%"
                    android:textSize="11sp"
                    android:textColor="#3B6D11"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Chuyển đổi -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2K"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chuyển đổi"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ +32%"
                    android:textSize="11sp"
                    android:textColor="#3B6D11"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Hài lòng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="89%"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hài lòng"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ +5%"
                    android:textSize="11sp"
                    android:textColor="#3B6D11"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Doanh thu -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.2tr"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Doanh thu"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ +24%"
                    android:textSize="11sp"
                    android:textColor="#3B6D11"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Campaign Card 1 — Golden Hour (Dark) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_camp_card_1"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="bottom"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦ Chiến dịch nổi bật"
                    android:textSize="11sp"
                    android:textColor="@color/gold2"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Golden Hour Beauty Ritual"
                    android:textSize="18sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem chi tiết →"
                    android:textSize="12sp"
                    android:textColor="@color/lilac2"
                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

        <!-- Campaign Card 2 — Botanica (Green) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_camp_card_2"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="bottom"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 Organic Series"
                    android:textSize="11sp"
                    android:textColor="@color/sage2"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back to Botanica Roots"
                    android:textSize="18sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khám phá →"
                    android:textSize="12sp"
                    android:textColor="@color/sage2"
                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

        <!-- Campaign Card 3 — Winter Glow (Lilac) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_camp_card_3"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="bottom"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💫 Holiday Edition"
                    android:textSize="11sp"
                    android:textColor="@color/lilac2"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Winter Glow Collection"
                    android:textSize="18sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tham gia →"
                    android:textSize="12sp"
                    android:textColor="@color/lilac2"
                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>
</ScrollView>