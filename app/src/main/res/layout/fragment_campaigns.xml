<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chiến dịch"
        android:textSize="24sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="@color/dark"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp" />

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btnCampRunning"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Đang chạy"
            android:textSize="13sp"
            android:background="@drawable/bg_btn_primary"
            android:textColor="@color/white"
            android:layout_marginEnd="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnCampUpcoming"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Sắp ra mắt"
            android:textSize="13sp"
            android:background="@android:color/transparent"
            android:textColor="@color/mid"
            android:layout_marginEnd="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnCampEnded"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Đã kết thúc"
            android:textSize="13sp"
            android:background="@android:color/transparent"
            android:textColor="@color/mid"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- Stats -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Item -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:text="24.8K"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Tiếp cận"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:text="1.2K"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Chuyển đổi"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:text="89%"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Hài lòng"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="12dp">

                <TextView
                    android:text="4.2tr"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Doanh thu"
                    android:textSize="11sp"
                    android:textColor="@color/mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- LIST FEED -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCampaigns"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"/>

</LinearLayout>