<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_profile_header"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Avatar -->
            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="NH"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Ngọc Hân"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/dark"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_points_card"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:elevation="2dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦ ĐIỂM TÍCH LŨY"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:textColor="@color/mid" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2,480"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark" />
            </LinearLayout>
        </LinearLayout>

        <!-- Menu: Tài khoản -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tài khoản"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/mid"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <!-- Menu Items — Tài khoản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Thông tin cá nhân -->
            <LinearLayout
                android:id="@+id/menuPersonalInfo"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_menu_icon_pink"
                    android:gravity="center" android:text="👤" android:textSize="18sp"
                    android:layout_marginEnd="14dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Thông tin cá nhân" android:textSize="14sp"
                        android:textColor="@color/dark" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Cập nhật hồ sơ" android:textSize="12sp"
                        android:textColor="@color/mid" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="@color/light_purple" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_color" android:layout_marginStart="54dp" />

            <!-- Điểm thưởng -->
            <LinearLayout
                android:id="@+id/menuPoints"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_menu_icon_lilac"
                    android:gravity="center" android:text="💎" android:textSize="18sp"
                    android:layout_marginEnd="14dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Điểm thưởng &amp; ưu đãi" android:textSize="14sp"
                        android:textColor="@color/dark" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2,480 điểm hiện có" android:textSize="12sp"
                        android:textColor="@color/mid" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="@color/light_purple" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_color" android:layout_marginStart="54dp" />
        </LinearLayout>

        <!-- Menu: Cài đặt -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cài đặt"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/mid"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Thông báo -->
            <LinearLayout
                android:id="@+id/menuNotif"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_menu_icon_sage"
                    android:gravity="center" android:text="🔔" android:textSize="18sp"
                    android:layout_marginEnd="14dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Thông báo" android:textSize="14sp"
                        android:textColor="@color/dark" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bật tất cả" android:textSize="12sp"
                        android:textColor="@color/mid" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="@color/light_purple" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_color" android:layout_marginStart="54dp" />

            <!-- Bảo mật -->
            <LinearLayout
                android:id="@+id/menuSecurity"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_menu_icon_lilac"
                    android:gravity="center" android:text="🔒" android:textSize="18sp"
                    android:layout_marginEnd="14dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bảo mật &amp; Quyền riêng tư" android:textSize="14sp"
                        android:textColor="@color/dark" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mật khẩu, 2FA" android:textSize="12sp"
                        android:textColor="@color/mid" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="@color/light_purple" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider_color" android:layout_marginStart="54dp" />

            <!-- Hỗ trợ -->
            <LinearLayout
                android:id="@+id/menuSupport"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_menu_icon_pink"
                    android:gravity="center" android:text="❓" android:textSize="18sp"
                    android:layout_marginEnd="14dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hỗ trợ &amp; Trợ giúp" android:textSize="14sp"
                        android:textColor="@color/dark" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Liên hệ với CSKH" android:textSize="12sp"
                        android:textColor="@color/mid" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="@color/light_purple" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>