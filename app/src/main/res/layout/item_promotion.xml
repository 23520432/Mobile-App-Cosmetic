<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:elevation="2dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_flash_sale">

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/imgPromo"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:layout_marginEnd="12dp"/>

        <!-- TEXT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên ưu đãi"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/dark"/>

            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mô tả"
                android:textSize="12sp"
                android:textColor="@color/dark2"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- BADGE -->
        <LinearLayout
            android:id="@+id/badgeContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_right_promo">

            <TextView
                android:id="@+id/tvDiscount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-20%"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>

    <!-- ✏️ EDIT + 🗑 DELETE -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="horizontal"
        android:elevation="10dp"
        android:layout_margin="8dp">

        <!-- EDIT -->
        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_hero_badge"
            android:src="@drawable/ic_edit"
            android:padding="8dp"
            android:layout_marginEnd="6dp"/>

        <!-- DELETE -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_hero_badge"
            android:src="@drawable/ic_delete"
            android:padding="8dp"/>

    </LinearLayout>

</FrameLayout>