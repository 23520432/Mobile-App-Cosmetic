<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvNotifEmoji"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_card_lilac"
        android:gravity="center"
        android:text="🌸"
        android:textSize="20sp"
        android:layout_marginEnd="14dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn nhận được ưu đãi VIP tháng này!"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark"
            android:layout_marginBottom="3dp" />

        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vừa xong"
            android:textSize="11sp"
            android:textColor="@color/mid" />

    </LinearLayout>

    <View
        android:id="@+id/unreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_badge_red"
        android:layout_marginStart="8dp"
        android:visibility="visible" />

</LinearLayout>